from socket import *
import sys
from urllib.parse import urlparse, quote_plus
import ssl
from bs4 import BeautifulSoup
import json, time, os


# Returns simple HTML structure, doesnt block scrapping so aggressively
search_engine = "html.duckduckgo.com" # results parsing is duckduckgo specific

nr_of_results_to_print = 10
snippet_max_length = 69 # because it wraps at 72 characters in the terminal, and we want to add "..." at the end if truncated

redirect_limit_global = 5

CACHE_FILE = "go2web_cache.json"

def parse_args():
    # parse command line arguments
    if len(sys.argv) <= 1:
        print("Error: wrong format.")
        sys.exit(1)

    elif len(sys.argv) == 2 and sys.argv[1] == "-h":
        show_help()
        sys.exit(0)

    elif len(sys.argv) == 3 and sys.argv[1] == "-u":
        url = sys.argv[2]
        host, port, path = parse_url(url)
        http_response = make_http_request_with_caching(host, port, path, redirect_limit=redirect_limit_global)

        header_info_dict = parse_response_header(http_response)
        print_response_header(header_info_dict)

        sys.exit(0)

    elif len(sys.argv) >= 3 and sys.argv[1] == "-s":
        term = " ".join(sys.argv[2:])
        path = build_search_path(term)

        http_response = make_http_request_with_caching(search_engine, 443, path, redirect_limit=redirect_limit_global)
        
        header_info_dict = parse_response_header(http_response)
        print_response_header(header_info_dict)
        
        search_results = parse_search_results(http_response)
        print_search_results(search_results, term)

        sys.exit(0)

    else:
        print("Error: wrong format.")
        sys.exit(1)

def show_help():
    print("Usage: go2web [options]")
    print("Options:")
    print("  -h                Show this help message and exit")
    print("  -u <URL>          Make an HTTP request to the specified URL and print the response")
    print(f"  -s <search terms> Make an HTTP request to search the term using {search_engine} and print top 10 results")

def parse_url(url):
    # urlparse() does not recognize google.com as a valid URL, so we need to add "http://" prefix if it's missing
    if "://" not in url:
        url = "http://" + url
    parsed_url = urlparse(url)

    if parsed_url.scheme not in ("http", "https"):
        print("Error: unsupported URL scheme.")
        sys.exit(1)

    if parsed_url.hostname is None or '.' not in parsed_url.hostname:
        print("Error: invalid host in URL.")
        sys.exit(1)

    host = parsed_url.hostname

    port = parsed_url.port
    if not port:
        port = 80

    # If the path is empty, set it to "/"
    path = parsed_url.path or "/"
    # If the URL contains a query string, append it to the path
    if parsed_url.query:
        path += "?" + parsed_url.query


    return host, port, path

def build_search_path(search_term):
    # URL-encode the search term and construct the DuckDuckGo search path
    encoded_term = quote_plus(search_term)
    return f"/html/?q={encoded_term}"
    
def make_http_request(host, port, path, redirect_limit):
    # Create a IPv4, TCP socket
    clientSocket = socket(AF_INET, SOCK_STREAM)

    # Establish a connection to the server
    #   expects host like google.com, no URL (with protocol http/https), or path (like /index.html)
    clientSocket.connect((host, port))

    # Send an HTTP GET request to the server
    #   Note: I was getting 400/406 when constructing the request using """...""" format
    http_request = (
        f"GET {path} HTTP/1.1\r\n"
        f"Host: {host}\r\n"
        f"Connection: close\r\n"
        f"\r\n"
    )

    #   If HTTPS is used, handle TLS (wrap the socket with SSL/TLS support)
    if port == 443:
        context = ssl.create_default_context()
        # wrap the existing socket with SSL/TLS support
        clientSocket = context.wrap_socket(clientSocket, server_hostname=host)

    clientSocket.sendall(http_request.encode())

    # Receive the HTTP response from the server
    http_response_binary = b""
    while True:
        chunk = clientSocket.recv(4096)
        if not chunk:
            break
        http_response_binary += chunk

    http_response = http_response_binary.decode(errors="replace")

    header_info_dict = parse_response_header(http_response)    

    # Handle redirects
    if header_info_dict["status_code"] in ("301", "302", "303", "307", "308"):
        if redirect_limit <= 0:
            print("Error: redirect limit reached.")
            sys.exit(1)
        
        location = header_info_dict.get("location")
        if location:
            print(f"Redirecting to: {location}\n")
            # If location is relative (starts with /), make it absolute
            if location.startswith("/"):
                scheme = "https" if port == 443 else "http"
                location = f"{scheme}://{host}{location}"
            
            new_host, new_port, new_path = parse_url(location)
            clientSocket.close()
            return make_http_request_with_caching(new_host, new_port, new_path, redirect_limit=redirect_limit - 1)
                      
    clientSocket.close()

    return http_response
    
def parse_response_header(http_response):
    # Extract response information
    header_end = http_response.find("\r\n\r\n")
    http_response_header = http_response[:header_end]

    status_line = http_response_header.splitlines()[0]
    protocol = status_line.split()[0]
    status_code = status_line.split()[1]
    status_message = " ".join(status_line.split()[2:])

    # Extract Date header
    try:
        date = http_response_header.split("Date: ")[1].split("\r\n")[0]
    except IndexError:
        date = "N/A"

    # Extract Expires header
    try:    
        expiration = http_response_header.split("Expires: ")[1].split("\r\n")[0]
    except IndexError:
        expiration = "N/A"
    
    # Extract Location header (for redirects)
    location = None
    try:
        location = http_response_header.split("Location: ")[1].split("\r\n")[0]
    except IndexError:
        location = None
    
    header_info_dict = {
        "protocol": protocol,
        "status_code": status_code,
        "status_message": status_message,
        "date": date,
        "expiration": expiration,
        "location": location
    }

    return header_info_dict

def print_response_header(header_info_dict):
    print("HTTP Response Header Information:")
    print(f"\tProtocol: {header_info_dict['protocol']}")
    print(f"\tStatus Code: {header_info_dict['status_code']}")
    print(f"\tStatus Message: {header_info_dict['status_message']}")
    print(f"\tDate: {header_info_dict['date']}")
    print(f"\tExpiration: {header_info_dict['expiration']}\n")

def parse_search_results(http_response):
    #  Extract the response body (HTML content) from the HTTP response
    response_body = http_response.split("\r\n\r\n", 1)[1]
    soup = BeautifulSoup(response_body, "html.parser")

    search_results_dicts = []

    # Find all result divs (with results)
    result_divs = soup.find_all("div", class_="result results_links results_links_deep web-result")
    
    for i, result_div in enumerate(result_divs[:nr_of_results_to_print]):
        try:
            # Title
            title_elem = result_div.find("h2", class_="result__title")
            title = title_elem.find("a").text.strip() if title_elem else "N/A"
            
            # URL
            url_elem = result_div.find("a", class_="result__url")
            url = url_elem.text.strip() if url_elem else "N/A"
            
            # Description/snippet
            snippet_elem = result_div.find("a", class_="result__snippet")
            snippet = snippet_elem.text.strip() if snippet_elem else "N/A"
            
            search_results_dicts.append({
                "title": title,
                "url": url,
                "snippet": snippet
            })
        except Exception as e:
            continue

    return search_results_dicts

def print_search_results(search_results_dicts, search_term):
    print(f"Top {len(search_results_dicts)} search results for '{search_term}':")

    for i, result in enumerate(search_results_dicts, start=1):
        print(f"\t{i}. {result['title']}")

        # add https:// to URLs to make clickable
        url = result['url']
        if not url.startswith(("http://", "https://")):
            url = "https://" + url
        print(f"\t   URL: {url}")

        # truncate the snippet
        snippet_text = result['snippet']
        truncated_snippet = snippet_text[:snippet_max_length]
        if len(snippet_text) > snippet_max_length:
            truncated_snippet += "..."
        print(f"\t   Snippet: {truncated_snippet}\n")

# caching-related
def load_cache():
    if os.path.exists(CACHE_FILE):
        try:
            with open(CACHE_FILE, 'r') as f:
                return json.load(f)
        except (json.JSONDecodeError, IOError):
            print("[Warning] Cache is corrupted, could not load")
            return {}
    
    with open(CACHE_FILE, 'w') as f:
        json.dump({}, f)
    return {}

def save_cache(cache):
    with open(CACHE_FILE, 'w') as f:
        json.dump(cache, f)

def make_http_request_with_caching(host, port, path, redirect_limit, ttl=60): #ttl in seconds
    cache = load_cache()

    full_url = f"{host}:{port}{path}"
    if full_url in cache:
        entry = cache[full_url]
        if time.time() - entry["timestamp"] < ttl:
            print(f"[Cache hit] {full_url}")
            return entry["response"]   # cache hit

    # Cache miss: fetch from network
    print(f"[Cache miss] {full_url}")
    response = make_http_request(host, port, path, redirect_limit)

    cache[full_url] = {"response": response, "timestamp": time.time()}
    save_cache(cache)
    return response


def main():
    parse_args()

if __name__ == "__main__":
    main()